# IMF.P.Security.BootstrapAll
# Purpose: Bootstrap the IMF security model and run hardening validation for a target environment.
# Sources:
# - IMF security control model
# - IMF.C.Version ownership metadata where applicable
# - TM1 native security control objects where applicable
# Parameters:
# - pEnvironment: Parameter pEnvironment Default 'DEV'.
# - pCreateIfExistsBehavior: Parameter pCreateIfExistsBehavior Default 'SKIP'.
# - pStrictMode: Parameter pStrictMode Default 'N'.
# - pLogToCube: Parameter pLogToCube Default 'Y'.
# - pLogFile: Parameter pLogFile Default 'docs/security/IMF_Security_Bootstrap.log'.
# Prolog:
# - Execute the process-specific security hardening workflow.
# Metadata:
# - No metadata datasource is required in this scaffold.
# Data:
# - No Data tab logic is implemented unless explicitly required later.
# Epilog:
# - Leave a deterministic log trail and clearly surface all TODOs.

#region prolog
sEnvironment = Upper(Trim(pEnvironment));
sCreateBehavior = Upper(Trim(pCreateIfExistsBehavior));
sStrictMode = Upper(Trim(pStrictMode));
sLogToCube = Upper(Trim(pLogToCube));
sLogFile = Trim(pLogFile);
If(sEnvironment @= ''); sEnvironment = 'DEV'; EndIf;
If(sCreateBehavior @= ''); sCreateBehavior = 'SKIP'; EndIf;
If(sStrictMode @= ''); sStrictMode = 'N'; EndIf;
ExecuteProcess('IMF.P.Security.LogSecurityEvent', 'pEnvironment', sEnvironment, 'pAction', 'BOOTSTRAP_START', 'pObjectType', 'SECURITY_MODEL', 'pObjectName', 'IMF', 'pStatus', 'INFO', 'pMessage', 'Security bootstrap started.', 'pLogToCube', sLogToCube, 'pLogFile', sLogFile);
ExecuteProcess('IMF.P.Security.CreateGroups', 'pEnvironment', sEnvironment, 'pCreateIfExistsBehavior', sCreateBehavior, 'pStrictMode', sStrictMode, 'pLogToCube', sLogToCube, 'pLogFile', sLogFile);
ExecuteProcess('IMF.P.Security.ApplyModel', 'pEnvironment', sEnvironment, 'pLogOnly', 'N', 'pLogToCube', sLogToCube, 'pLogFile', sLogFile);
ExecuteProcess('IMF.P.Security.ValidateFullModel', 'pEnvironment', sEnvironment, 'pOutputFile', 'docs/security/IMF_Security_Matrix.csv', 'pLogToCube', sLogToCube, 'pLogFile', sLogFile);
ExecuteProcess('IMF.P.Security.ExportProcessMatrix', 'pEnvironment', sEnvironment, 'pOutputFile', 'docs/security/IMF_Process_Security_Matrix.csv', 'pLogToCube', sLogToCube, 'pLogFile', sLogFile);
ExecuteProcess('IMF.P.Security.ExportSecurityMatrix', 'pEnvironment', sEnvironment, 'pOutputFile', 'docs/security/IMF_Security_Matrix.csv', 'pLogToCube', sLogToCube, 'pLogFile', sLogFile);
ExecuteProcess('IMF.P.Security.ExportSecurityAudit', 'pEnvironment', sEnvironment, 'pOutputFile', 'docs/security/IMF_Security_Audit.csv', 'pLogToCube', sLogToCube, 'pLogFile', sLogFile);
ExecuteProcess('IMF.P.Security.RunSecurityRegressionSuite', 'pEnvironment', sEnvironment, 'pLogToCube', sLogToCube, 'pLogFile', sLogFile);
ExecuteProcess('IMF.P.Security.LogSecurityEvent', 'pEnvironment', sEnvironment, 'pAction', 'BOOTSTRAP_END', 'pObjectType', 'SECURITY_MODEL', 'pObjectName', 'IMF', 'pStatus', 'INFO', 'pMessage', 'Security bootstrap completed.', 'pLogToCube', sLogToCube, 'pLogFile', sLogFile);
#endregion

#region metadata
# TODO: Add metadata-tab logic only if a real datasource is required.
#endregion

#region data
# No Data tab logic in this scaffold.
#endregion

#region epilog
# No Epilog tab logic beyond logging for this scaffold.
#endregion
