# Intito MasterFlow rollback validation
# Purpose: Validate that an archive dimension can safely be restored as master.
# Sources:
# - IMF.D.Dimension
# - Selected archive dimension
# Parameters:
# - pPrefix: Naming prefix for Intito MasterFlow control objects. Default 'IMF'.
# - pDimensionCode: Managed dimension code.
# - pArchiveName: Existing archive dimension.
# Prolog:
# - Validate rollback inputs and archive existence.
# Metadata:
# - Resolve restore preconditions and archive metadata requirements.
# Data:
# - Inspect archive structure and required attributes.
# Epilog:
# - Return control to the rollback process when the archive is considered valid.

#region prolog
sPrefix = Trim(pPrefix);
If(sPrefix @= '');
  sPrefix = 'IMF';
EndIf;

sDimensionCode = Trim(pDimensionCode);
sArchiveName = Trim(pArchiveName);

sDimDimension = sPrefix | '.D.Dimension';

If((sDimensionCode @= '') % (sArchiveName @= ''));
  ProcessBreak;
EndIf;
If(DimensionElementExists(sDimDimension, sDimensionCode) = 0);
  ProcessBreak;
EndIf;
If(DimensionExists(sArchiveName) = 0);
  ProcessBreak;
EndIf;
sMasterDimension = Trim(AttrS(sDimDimension, sDimensionCode, 'MasterDimensionName'));
If(sMasterDimension @= '');
  sMasterDimension = sDimensionCode;
EndIf;
If(sArchiveName @= sMasterDimension);
  ProcessBreak;
EndIf;
If(DimensionExists(sMasterDimension) = 0);
  ProcessBreak;
EndIf;

If(DimensionExists('}ElementAttributes_' | sArchiveName) = 0);
  ProcessBreak;
EndIf;
#endregion

#region metadata
#endregion

#region data
#endregion

#region epilog
#endregion
