# Intito MasterFlow import CSV parent-child
# Purpose: Import parent-child CSV rows into a managed dimension or work version.
#
# Parameters:
#   pPrefix         Default 'IMF'
#   pDimensionCode  Managed dimension code
#   pVersionId      Optional work version
#   pFilePath       Source file path

sPrefix = Trim(pPrefix);
If(sPrefix @= '');
  sPrefix = 'IMF';
EndIf;

