    "Prolog":  "sEnvironment = Upper(Trim(pEnvironment));\r\nsAction = Trim(pAction);\r\nsObjectType = Trim(pObjectType);\r\nsObjectName = Trim(pObjectName);\r\nsStatus = Upper(Trim(pStatus));\r\nsMessage = Trim(pMessage);\r\nsLogToCube = Upper(Trim(pLogToCube));\r\nsLogFile = Trim(pLogFile);\r\nIf(sStatus @= \u0027\u0027); sStatus = \u0027INFO\u0027; EndIf;\r\nIf(sLogToCube @= \u0027\u0027); sLogToCube = \u0027Y\u0027; EndIf;\r\nIf(sLogFile @= \u0027\u0027); sLogFile = \u0027docs/security/IMF_Security_Bootstrap.log\u0027; EndIf;\r\nsLogLine = \u0027[IMF_SECURITY][\u0027 | sEnvironment | \u0027][\u0027 | sStatus | \u0027][\u0027 | sAction | \u0027][\u0027 | sObjectType | \u0027][\u0027 | sObjectName | \u0027] \u0027 | sMessage;\r\nIf(sLogToCube @= \u0027Y\u0027);\r\n  # TODO: Write to IMF.C.EventLog once the cube grain and insertion convention are finalized.\r\nEndIf;\r\nASCIIOutput(sLogFile, sLogLine);\r\nLogOutput(\u0027INFO\u0027, sLogLine);",
