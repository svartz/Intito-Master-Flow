# Intito MasterFlow import CSV leaf-flat
# Purpose: Import flat leaf-level CSV rows into a managed dimension or work version.
#
# Parameters:
#   pPrefix         Default 'IMF'
#   pDimensionCode  Managed dimension code
#   pVersionId      Optional work version
#   pFilePath       Source file path

sPrefix = Trim(pPrefix);
If(sPrefix @= '');
  sPrefix = 'IMF';
EndIf;

